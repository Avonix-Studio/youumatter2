{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "yum2/pullquote",
  "title": "YouuMatter Pull Quote",
  "description": "A branded pull-quote in Newsreader italic with an optional attribution line.",
  "category": "text",
  "icon": "format-quote",
  "textdomain": "youumatter2",
  "attributes": {
    "quote":       { "type": "string", "default": "" },
    "attribution": { "type": "string", "default": "" }
  },
  "supports": {
    "html": false,
    "align": ["wide"]
  },
  "editorScript": false,
  "viewScript": false
}
