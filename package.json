{
  "name": "youumatter2",
  "version": "1.0.1",
  "private": true,
  "description": "Tailwind toolchain for the youumatter2 WordPress theme.",
  "scripts": {
    "dev": "tailwindcss -i ./assets/css/tailwind.src.css -o ./assets/css/main.css --watch",
    "build": "tailwindcss -i ./assets/css/tailwind.src.css -o ./assets/css/main.css --minify",
    "build:editor": "tailwindcss -i ./assets/css/tailwind.editor.src.css -o ./assets/css/editor.css --minify",
    "build:all": "npm run build && npm run build:editor"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "tailwindcss": "^3.4.0"
  }
}
